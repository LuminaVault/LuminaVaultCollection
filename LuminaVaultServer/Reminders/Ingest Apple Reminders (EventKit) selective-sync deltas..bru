meta {
  name: Ingest Apple Reminders (EventKit) selective-sync deltas.
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/v1/reminders/sync
  body: json
  auth: inherit
}

body:json {
  {
    "reminders": [
      {
        "externalID": "",
